<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Peak.GamePerformanceDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Peak"
    BackgroundColor="#F5F6FA"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <Grid x:Name="HeroSection"
                  Padding="20,34,20,28"
                  RowDefinitions="Auto,Auto,Auto"
                  MinimumHeightRequest="330">
                <Border x:Name="HeroGlowOne"
                        WidthRequest="170"
                        HeightRequest="170"
                        Opacity="0.12"
                        HorizontalOptions="End"
                        VerticalOptions="Start"
                        TranslationX="48"
                        TranslationY="-12"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 85"
                        BackgroundColor="White" />

                <Border x:Name="HeroGlowTwo"
                        WidthRequest="120"
                        HeightRequest="120"
                        Opacity="0.10"
                        HorizontalOptions="End"
                        VerticalOptions="Center"
                        TranslationX="12"
                        TranslationY="12"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 60"
                        BackgroundColor="White" />

                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="14">
                    <Border WidthRequest="34"
                            HeightRequest="34"
                            BackgroundColor="#1AFFFFFF"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 17">
                        <Label Text="&lt;"
                               FontSize="18"
                               TextColor="White"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Label x:Name="GameTitleLabel"
                           Grid.Column="1"
                           Text="GAME"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"
                           VerticalTextAlignment="Center" />

                    <Label x:Name="HeroWatermarkLabel"
                           Grid.Column="2"
                           Text="SC"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#F2FFFFFF"
                           HorizontalTextAlignment="End"
                           VerticalTextAlignment="Center" />
                </Grid>

                <VerticalStackLayout Grid.Row="1"
                                     Margin="0,22,0,0"
                                     Spacing="16">
                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="14"
                          RowSpacing="14">
                        <Border Grid.Row="0"
                                Grid.Column="0"
                                BackgroundColor="#18FFFFFF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20"
                                Padding="14,12">
                            <VerticalStackLayout Spacing="4">
                                <Label x:Name="BestScoreValueLabel"
                                       Text="0"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                                <Label Text="BEST SCORE"
                                       FontSize="12"
                                       CharacterSpacing="1"
                                       TextColor="#E8FFFFFF" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="0"
                                Grid.Column="1"
                                BackgroundColor="#18FFFFFF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20"
                                Padding="14,12">
                            <VerticalStackLayout Spacing="4">
                                <Label x:Name="GameRankValueLabel"
                                       Text="Beginner"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                                <Label Text="GAME RANK"
                                       FontSize="12"
                                       CharacterSpacing="1"
                                       TextColor="#E8FFFFFF" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.Column="0"
                                BackgroundColor="#18FFFFFF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20"
                                Padding="14,12">
                            <VerticalStackLayout Spacing="4">
                                <Label x:Name="PeakGameScoreValueLabel"
                                       Text="0"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                                <Label Text="PEAK GAME SCORE"
                                       FontSize="12"
                                       CharacterSpacing="1"
                                       TextColor="#E8FFFFFF" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.Column="1"
                                BackgroundColor="#18FFFFFF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20"
                                Padding="14,12">
                            <VerticalStackLayout Spacing="4">
                                <Label x:Name="SessionsValueLabel"
                                       Text="0"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                                <Label Text="SESSIONS PLAYED"
                                       FontSize="12"
                                       CharacterSpacing="1"
                                       TextColor="#E8FFFFFF" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Button x:Name="PlayButton"
                            Text="PLAY GAME"
                            Clicked="OnPlayClicked"
                            CornerRadius="24"
                            HeightRequest="48"
                            HorizontalOptions="Center"
                            WidthRequest="206"
                            BackgroundColor="White"
                            TextColor="#5A58E7"
                            FontAttributes="Bold" />
                </VerticalStackLayout>
            </Grid>

            <Border BackgroundColor="#F5F6FA"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 30"
                    Margin="0,-16,0,0">
                <VerticalStackLayout Padding="20,24,20,32"
                                     Spacing="22">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="YOUR TREND SO FAR"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#545862" />
                        <Label x:Name="TrendSubtitleLabel"
                               Text="Discover how you have done over time"
                               FontSize="14"
                               TextColor="#9499A5" />
                    </VerticalStackLayout>

                    <local:MiniAreaCard x:Name="TrendCard"
                                        Title="PEAK GAME SCORE"
                                        Score="0"
                                        MaxScale="1000"
                                        StartPeriodLabel="1w"
                                        EndPeriodLabel="Today" />

                    <BoxView HeightRequest="1"
                             BackgroundColor="#E4E6EB" />

                    <VerticalStackLayout Spacing="2">
                        <Label Text="YOUR TOP 5 SCORES"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#545862" />
                        <Label x:Name="TopScoresSubtitleLabel"
                               Text="Your top scores"
                               FontSize="14"
                               TextColor="#9499A5" />
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="TopScoresHost"
                                         Spacing="14" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
