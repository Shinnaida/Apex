<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Peak.BabbleBotsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#635BEE"
    Shell.NavBarIsVisible="False">

    <Grid>
        <Grid RowDefinitions="*,Auto">
            <ScrollView Grid.Row="0">
                <VerticalStackLayout Padding="22,18,22,30" Spacing="18">

                    <Grid ColumnDefinitions="Auto,*">
                        <Label Text="&#x2190;"
                               FontSize="28"
                               TextColor="White"
                               VerticalOptions="Start">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <Grid ColumnDefinitions="*,180" Margin="0,8,0,0">
                        <VerticalStackLayout Grid.Column="0" Spacing="8">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="Babble Bots"
                                       FontSize="30"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                                <Label Text="☆"
                                       FontSize="26"
                                       TextColor="White"
                                       Opacity="0.95" />
                            </HorizontalStackLayout>

                            <Label Text="Language"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="#F0EEFF" />

                            <BoxView HeightRequest="2"
                                     WidthRequest="190"
                                     HorizontalOptions="Start"
                                     Color="#D9D4FF" />

                            <Grid ColumnDefinitions="40,*" Margin="0,10,0,0">
                                <Frame WidthRequest="32"
                                       HeightRequest="32"
                                       CornerRadius="16"
                                       Padding="0"
                                       BackgroundColor="Transparent"
                                       BorderColor="#D9D4FF"
                                       HasShadow="False">
                                    <Label Text="★"
                                           FontSize="15"
                                           TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" Spacing="0">
                                    <Label Text="Best Rank"
                                           FontSize="14"
                                           TextColor="#E8E3FF" />
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Beginner"
                                               FontSize="22"
                                               FontAttributes="Bold"
                                               TextColor="White" />
                                        <Label Text="i"
                                               FontSize="16"
                                               TextColor="White" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>

                        <Grid Grid.Column="1"
                              WidthRequest="180"
                              HeightRequest="180"
                              HorizontalOptions="End"
                              VerticalOptions="Start">
                            <Frame CornerRadius="90"
                                   BackgroundColor="#564DE1"
                                   HasShadow="False"
                                   Padding="0">
                                <Grid Padding="18">
                                    <Frame BackgroundColor="#7B73F5"
                                           CornerRadius="12"
                                           HeightRequest="42"
                                           WidthRequest="88"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Start"
                                           TranslationY="8"
                                           HasShadow="False" />

                                    <Frame BackgroundColor="#C8C5FF"
                                           CornerRadius="12"
                                           HeightRequest="38"
                                           WidthRequest="82"
                                           HorizontalOptions="End"
                                           VerticalOptions="Start"
                                           TranslationX="12"
                                           TranslationY="20"
                                           HasShadow="False"
                                           Opacity="0.9" />

                                    <Grid VerticalOptions="End"
                                          ColumnDefinitions="*,*"
                                          ColumnSpacing="16"
                                          Margin="10,0,10,12">
                                        <Grid Grid.Column="0" RowDefinitions="50,54" WidthRequest="58">
                                            <Frame BackgroundColor="#736CF4" HasShadow="False" CornerRadius="12" Padding="0" />
                                            <Grid Padding="10,12,10,0">
                                                <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5" Color="White" HorizontalOptions="Start" />
                                                <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5" Color="White" HorizontalOptions="End" />
                                                <BoxView HeightRequest="4" WidthRequest="24" CornerRadius="2" Color="#564DE1" VerticalOptions="End" HorizontalOptions="Center" Margin="0,0,0,8" />
                                            </Grid>
                                            <Frame Grid.Row="1" BackgroundColor="#4F8CF3" HasShadow="False" CornerRadius="10" Padding="0" />
                                        </Grid>

                                        <Grid Grid.Column="1" RowDefinitions="50,54" WidthRequest="58">
                                            <Frame BackgroundColor="#F7F6FF" HasShadow="False" CornerRadius="12" Padding="0" />
                                            <Grid Padding="10,12,10,0">
                                                <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5" Color="#564DE1" HorizontalOptions="Start" />
                                                <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5" Color="#564DE1" HorizontalOptions="End" />
                                                <BoxView HeightRequest="4" WidthRequest="24" CornerRadius="2" Color="#8E87FF" VerticalOptions="End" HorizontalOptions="Center" Margin="0,0,0,8" />
                                            </Grid>
                                            <Frame Grid.Row="1" BackgroundColor="#9B95FF" HasShadow="False" CornerRadius="10" Padding="0" />
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Frame>
                        </Grid>
                    </Grid>

                    <Frame CornerRadius="18"
                           BackgroundColor="White"
                           HasShadow="False"
                           Padding="20,16">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Text="🏆"
                                   FontSize="22"
                                   TextColor="#7A72F8"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="BEST SCORE"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#7A72F8"
                                   VerticalOptions="Center"
                                   Margin="12,0,0,0" />
                            <Label x:Name="BestScoreValueLabel"
                                   Grid.Column="2"
                                   Text="0"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#333333"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Frame>

                    <Button Text="HOW TO PLAY"
                            BackgroundColor="#2132B8"
                            TextColor="White"
                            CornerRadius="14"
                            HeightRequest="56"
                            FontSize="16"
                            FontAttributes="Bold"
                            Clicked="OnHowToPlayClicked" />

                    <Frame CornerRadius="20"
                           BackgroundColor="White"
                           HasShadow="False"
                           Padding="18,18,18,20"
                           Margin="0,10,0,0">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="Challenge"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#7A72F8" />
                            <BoxView HeightRequest="1" Color="#D9D9D9" />
                            <Label Text="Score above 2080 to rank up to Novice"
                                   FontSize="16"
                                   TextColor="#444444" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame CornerRadius="20"
                           BackgroundColor="White"
                           HasShadow="False"
                           Padding="18,18,18,20">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="Skills"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#7A72F8" />
                            <BoxView HeightRequest="1" Color="#D9D9D9" />

                            <Frame CornerRadius="12"
                                   BackgroundColor="#F6F6FF"
                                   HasShadow="False"
                                   Padding="14,10">
                                <Label Text="Word Fluency"
                                       FontSize="16"
                                       TextColor="#333333" />
                            </Frame>

                            <Frame CornerRadius="12"
                                   BackgroundColor="#F6F6FF"
                                   HasShadow="False"
                                   Padding="14,10">
                                <Label Text="Vocabulary"
                                       FontSize="16"
                                       TextColor="#333333" />
                            </Frame>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>
            </ScrollView>

            <Grid Grid.Row="1"
                  Padding="20,10,20,24"
                  BackgroundColor="#635BEE">
                <Button Text="PLAY"
                        HeightRequest="64"
                        CornerRadius="32"
                        BackgroundColor="White"
                        TextColor="#7A72F8"
                        FontSize="22"
                        FontAttributes="Bold"
                        Clicked="OnPlayClicked" />
            </Grid>
        </Grid>

        <Grid x:Name="HowToPlayOverlay"
              IsVisible="False"
              Opacity="0"
              ZIndex="10">
            <BoxView BackgroundColor="#80000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnOverlayTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Grid VerticalOptions="End"
                  Padding="12,0,12,20">
                <Frame x:Name="HowToPlayPanel"
                       CornerRadius="28"
                       BackgroundColor="White"
                       HasShadow="False"
                       Padding="20"
                       TranslationY="500">
                    <VerticalStackLayout Spacing="16">
                        <BoxView HeightRequest="5"
                                 WidthRequest="46"
                                 Color="#D0D0D0"
                                 HorizontalOptions="Center" />

                        <Label Text="How to Play"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#222"
                               HorizontalOptions="Center" />

                        <Label Text="Each bot gives you a letter bank. Build as many valid words as you can from those letters before the timer runs out."
                               FontSize="16"
                               TextColor="#555" />

                        <Label Text="- Tap letters to build a word&#10;- Submit valid words to score and build combos&#10;- Shuffle or delete letters whenever you need a reset"
                               FontSize="16"
                               TextColor="#444" />

                        <Button Text="Got it"
                                HeightRequest="54"
                                CornerRadius="27"
                                BackgroundColor="#4B4AE8"
                                TextColor="White"
                                Clicked="OnCloseHowToPlayClicked" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
