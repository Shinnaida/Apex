<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Peak.TurtleTrafficPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#0D73F2"
    Shell.NavBarIsVisible="False">

    <!-- ONE ROOT ONLY -->
    <Grid>

        <!-- MAIN PAGE -->
        <Grid RowDefinitions="*,Auto">

            <ScrollView Grid.Row="0">
                <VerticalStackLayout Padding="20,18,20,30" Spacing="18">

                    <!-- Top -->
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Text="←"
                               FontSize="28"
                               TextColor="White"
                               VerticalOptions="Start">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <!-- Header -->
                    <Grid ColumnDefinitions="*,170" Margin="0,10,0,0">
                        <VerticalStackLayout Grid.Column="0" Spacing="8">

                            <Label Text="Turtle Traffic"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="White"/>

                            <Label Text="Mental Agility"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="White"/>

                            <BoxView HeightRequest="2"
                                     WidthRequest="180"
                                     HorizontalOptions="Start"
                                     Color="#8FD0FF"/>

                            <Grid ColumnDefinitions="40,*" Margin="0,10,0,0">
                                <Frame WidthRequest="32"
                                       HeightRequest="32"
                                       CornerRadius="16"
                                       Padding="0"
                                       BackgroundColor="Transparent"
                                       BorderColor="#A9D6FF"
                                       HasShadow="False"
                                       VerticalOptions="Start">
                                    <Label Text="★"
                                           FontSize="16"
                                           TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" Spacing="0">
                                    <Label Text="Best Rank"
                                           FontSize="14"
                                           TextColor="#CFE8FF"/>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Beginner"
                                               FontSize="20"
                                               FontAttributes="Bold"
                                               TextColor="White"/>
                                        <Label Text="i"
                                               FontSize="16"
                                               TextColor="White"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- turtle art placeholder -->
                        <Grid Grid.Column="1"
                              WidthRequest="170"
                              HeightRequest="170"
                              HorizontalOptions="End"
                              VerticalOptions="Start">
                            <Frame CornerRadius="85"
                                   BackgroundColor="#2B8AF5"
                                   HasShadow="False"
                                   Padding="0">
                                <Label Text="🐢"
                                       FontSize="78"
                                       TextColor="#BFE0FF"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Frame>
                        </Grid>
                    </Grid>

                    <!-- Best Score -->
                    <Frame CornerRadius="18"
                           BackgroundColor="White"
                           HasShadow="False"
                           Padding="20,16">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Text="🏆"
                                   FontSize="22"
                                   TextColor="#4CA7FF"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="BEST SCORE"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#3399FF"
                                   VerticalOptions="Center"
                                   Margin="12,0,0,0"/>
                            <Label Grid.Column="2"
                                   Text="0"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#333333"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Frame>

                    <!-- Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                        <Button Grid.Column="0"
                                Text="HOW TO PLAY"
                                BackgroundColor="#0058DA"
                                TextColor="White"
                                CornerRadius="14"
                                HeightRequest="56"
                                FontSize="16"
                                FontAttributes="Bold"
                                Clicked="OnHowToPlayClicked"/>

                        <Button Grid.Column="1"
                                Text="SWITCH GAME"
                                BackgroundColor="#0058DA"
                                TextColor="White"
                                CornerRadius="14"
                                HeightRequest="56"
                                FontSize="16"
                                FontAttributes="Bold"/>
                    </Grid>

                    <!-- Challenge -->
                    <Frame CornerRadius="20"
                           BackgroundColor="White"
                           HasShadow="False"
                           Padding="18,18,18,20"
                           Margin="0,10,0,0">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="Challenge"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#3399FF"/>

                            <BoxView HeightRequest="1"
                                     Color="#D9D9D9"/>

                            <Label Text="Score above 3390 to rank up to Novice"
                                   FontSize="16"
                                   TextColor="#444444"/>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Skills -->
                    <Frame CornerRadius="20"
                           BackgroundColor="White"
                           HasShadow="False"
                           Padding="18,18,18,20">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="Skills"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#3399FF"/>

                            <BoxView HeightRequest="1"
                                     Color="#D9D9D9"/>

                            <Frame CornerRadius="12"
                                   BackgroundColor="#F6F6F6"
                                   HasShadow="False"
                                   Padding="14,10">
                                <Label Text="Task Shifting"
                                       FontSize="16"
                                       TextColor="#333333"/>
                            </Frame>

                            <Frame CornerRadius="12"
                                   BackgroundColor="#F6F6F6"
                                   HasShadow="False"
                                   Padding="14,10">
                                <Label Text="Hand-eye coordination"
                                       FontSize="16"
                                       TextColor="#333333"/>
                            </Frame>

                            <Frame CornerRadius="12"
                                   BackgroundColor="#F6F6F6"
                                   HasShadow="False"
                                   Padding="14,10">
                                <Label Text="Response Control"
                                       FontSize="16"
                                       TextColor="#333333"/>
                            </Frame>
                        </VerticalStackLayout>
                    </Frame>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Bottom play button -->
            <Grid Grid.Row="1"
                  Padding="20,10,20,24"
                  BackgroundColor="#0D73F2">
                <Button Text="PLAY"
                        HeightRequest="64"
                        CornerRadius="32"
                        BackgroundColor="White"
                        TextColor="#2A9AF6"
                        FontSize="22"
                        FontAttributes="Bold"
                        Clicked="OnPlayClicked"/>
            </Grid>
        </Grid>

        <!-- HOW TO PLAY OVERLAY -->
        <Grid x:Name="HowToPlayOverlay"
              IsVisible="False"
              Opacity="0"
              ZIndex="10">

            <!-- dark background -->
            <BoxView BackgroundColor="#80000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnOverlayTapped"/>
                </BoxView.GestureRecognizers>
            </BoxView>

            <!-- bottom sheet -->
            <Grid VerticalOptions="End"
                  Padding="12,0,12,20">

                <Frame x:Name="HowToPlayPanel"
                       CornerRadius="28"
                       BackgroundColor="White"
                       HasShadow="False"
                       Padding="20"
                       TranslationY="500">

                    <VerticalStackLayout Spacing="16">

                        <BoxView HeightRequest="5"
                                 WidthRequest="46"
                                 Color="#D0D0D0"
                                 HorizontalOptions="Center"/>

                        <Label Text="How to Play"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#222"
                               HorizontalOptions="Center"/>

                        <Label Text="Guide the turtle safely through traffic. Avoid collisions and react quickly to changing movement patterns."
                               FontSize="16"
                               TextColor="#555"/>

                        <Label Text="• Watch the movement carefully&#10;• Tap at the right time&#10;• Stay accurate and consistent"
                               FontSize="16"
                               TextColor="#444"/>

                        <Button Text="Got it"
                                HeightRequest="54"
                                CornerRadius="27"
                                BackgroundColor="#0D73F2"
                                TextColor="White"
                                Clicked="OnCloseHowToPlayClicked"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </Grid>

    </Grid>
</ContentPage>