<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Peak.ComparePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F6F4F6"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <Grid BackgroundColor="#10A7E6"
              Padding="18,18,18,14"
              RowDefinitions="Auto,Auto,Auto">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="14">
                <Label Text="←"
                       FontSize="22"
                       TextColor="White"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Grid.Column="1"
                       Text="HOW DO YOU COMPARE?"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"
                       VerticalOptions="Center" />
            </Grid>

            <Label Grid.Row="1"
                   Margin="0,14,0,0"
                   Text="Compare your performance to a group of Peak users, or connect to Facebook and face your friends."
                   FontSize="13"
                   TextColor="#DFF6FF" />

            <Grid Grid.Row="2"
                  Margin="0,16,0,0"
                  ColumnDefinitions="*,*"
                  RowDefinitions="Auto,3">
                <Label x:Name="AgeTabLabel"
                       Text="AGE"
                       FontSize="17"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAgeTabTapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label x:Name="ProfessionTabLabel"
                       Grid.Column="1"
                       Text="PROFESSION"
                       FontSize="17"
                       FontAttributes="Bold"
                       TextColor="#D8F4FF"
                       HorizontalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfessionTabTapped" />
                    </Label.GestureRecognizers>
                </Label>

                <BoxView x:Name="TabUnderline"
                         Grid.Row="1"
                         Grid.Column="0"
                         HeightRequest="3"
                         BackgroundColor="White"
                         Margin="44,0" />
            </Grid>
        </Grid>

        <CollectionView Grid.Row="1"
                        x:Name="OptionsCollection"
                        SelectionMode="None"
                        Margin="0,0,0,8">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="18,14"
                          ColumnDefinitions="*,Auto">
                        <Label Text="{Binding Label}"
                               FontSize="18"
                               TextColor="#707070"
                               VerticalOptions="Center" />

                        <Border Grid.Column="1"
                                WidthRequest="22"
                                HeightRequest="22"
                                BackgroundColor="Transparent"
                                Stroke="#D8D0DB"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 11"
                                VerticalOptions="Center"
                                IsVisible="{Binding IsSelected}" />

                        <BoxView Grid.ColumnSpan="2"
                                 HeightRequest="1"
                                 BackgroundColor="#E4DEE6"
                                 VerticalOptions="End" />

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOptionTapped" />
                        </Grid.GestureRecognizers>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
