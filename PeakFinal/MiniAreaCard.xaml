<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Peak.MiniAreaCard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Peak">

    <VerticalStackLayout Spacing="8">
        <Label x:Name="TitleLabel"
               Text="TITLE"
               FontSize="17"
               FontAttributes="Bold"
               TextColor="#11A7D8"
               Margin="2,0,0,0" />

        <Border BackgroundColor="White"
                Stroke="#ECEDEF"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 6"
                Padding="0">
            <Grid RowDefinitions="Auto,*,Auto"
                  ColumnDefinitions="Auto,*"
                  Padding="0"
                  MinimumHeightRequest="168">
                <Label x:Name="TopAxisLabel"
                       Grid.Row="0"
                       Grid.Column="0"
                       Margin="6,8,0,0"
                       Text="200"
                       FontSize="15"
                       TextColor="#444444" />

                <Grid Grid.Row="1"
                      Grid.ColumnSpan="2"
                      Margin="0,2,0,0">
                    <local:MiniAreaChart
                        x:Name="Chart"
                        VerticalOptions="Fill"
                        HorizontalOptions="Fill"
                        HeightRequest="126" />

                    <Grid x:Name="ScoreTagContainer"
                          HorizontalOptions="End"
                          VerticalOptions="Start"
                          Margin="0,10,-2,0"
                          InputTransparent="True">
                        <Border x:Name="ScoreBubble"
                                BackgroundColor="#707070"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 3"
                                Padding="11,7,11,7"
                                HorizontalOptions="End"
                                VerticalOptions="Start">
                            <Label x:Name="ScoreLabel"
                                   Text="163"
                                   TextColor="White"
                                   FontAttributes="Bold"
                                   FontSize="15" />
                        </Border>

                        <Border BackgroundColor="#707070"
                                StrokeThickness="0"
                                WidthRequest="10"
                                HeightRequest="10"
                                Rotation="45"
                                HorizontalOptions="Start"
                                VerticalOptions="End"
                                Margin="0,0,0,18" />
                    </Grid>
                </Grid>

                <Label x:Name="ZeroAxisLabel"
                       Grid.Row="1"
                       Grid.Column="0"
                       Margin="6,0,0,5"
                       Text="0"
                       FontSize="15"
                       TextColor="#444444"
                       VerticalOptions="End" />

                <Grid Grid.Row="2"
                      Grid.ColumnSpan="2"
                      Padding="6,0,10,8">
                    <HorizontalStackLayout x:Name="AxisLabelsHost"
                                           Spacing="0"
                                           HorizontalOptions="Fill"
                                           VerticalOptions="End" />
                </Grid>
            </Grid>
        </Border>
    </VerticalStackLayout>
</ContentView>
