<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Peak.PerilousPathPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F4A317"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,18,20,24" Spacing="18">

                <Label Text="&#x2190;"
                       FontSize="28"
                       TextColor="White">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Grid ColumnDefinitions="*,170" Margin="0,10,0,0">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Perilous Path"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="White"
                               LineHeight="0.95" />

                        <Label Text="Memory"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="White" />

                        <BoxView HeightRequest="1"
                                 WidthRequest="180"
                                 HorizontalOptions="Start"
                                 Color="#FFD690" />

                        <Grid ColumnDefinitions="42,*"
                              Margin="0,10,0,0">
                            <Frame WidthRequest="32"
                                   HeightRequest="32"
                                   CornerRadius="16"
                                   BackgroundColor="Transparent"
                                   BorderColor="#FFD690"
                                   HasShadow="False"
                                   VerticalOptions="Start"
                                   Padding="0">
                                <Label Text="&#x2605;"
                                       FontSize="16"
                                       TextColor="#FFE4B8"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Frame>

                            <VerticalStackLayout Grid.Column="1" Spacing="0">
                                <Label Text="Best Rank"
                                       FontSize="14"
                                       TextColor="#FFF0D4" />
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="Beginner"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                    <Label Text="i"
                                           FontSize="16"
                                           TextColor="White" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>

                    <Grid Grid.Column="1"
                          WidthRequest="170"
                          HeightRequest="170"
                          HorizontalOptions="End"
                          VerticalOptions="Start">

                        <Frame CornerRadius="85"
                               BackgroundColor="#E89A14"
                               HasShadow="False"
                               Padding="0" />

                        <Frame WidthRequest="128"
                               HeightRequest="128"
                               CornerRadius="10"
                               Padding="6"
                               BackgroundColor="#F6C35F"
                               HasShadow="False"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">

                            <Grid RowDefinitions="*,*,*"
                                  ColumnDefinitions="*,*,*"
                                  RowSpacing="2"
                                  ColumnSpacing="2">
                                <BoxView Grid.Row="0" Grid.Column="0" Color="#F9D996" />
                                <BoxView Grid.Row="0" Grid.Column="1" Color="#F9D996" />
                                <BoxView Grid.Row="0" Grid.Column="2" Color="#F9D996" />
                                <BoxView Grid.Row="1" Grid.Column="0" Color="#F9D996" />
                                <BoxView Grid.Row="1" Grid.Column="1" Color="#FFE6B5" />
                                <BoxView Grid.Row="1" Grid.Column="2" Color="#F2B946" />
                                <BoxView Grid.Row="2" Grid.Column="0" Color="#F9D996" />
                                <BoxView Grid.Row="2" Grid.Column="1" Color="#F2B946" />
                                <BoxView Grid.Row="2" Grid.Column="2" Color="#FFE6B5" />

                                <Label Grid.Row="1"
                                       Grid.Column="1"
                                       Text="&#x2739;"
                                       FontSize="26"
                                       TextColor="#E39A22"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Frame>
                    </Grid>
                </Grid>

                <Frame CornerRadius="18"
                       BackgroundColor="White"
                       HasShadow="False"
                       Padding="20,16">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="&#x1F3C6;"
                               FontSize="22"
                               TextColor="#E8A215"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="BEST SCORE"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#E8A215"
                               VerticalOptions="Center"
                               Margin="12,0,0,0" />
                        <Label x:Name="BestScoreValueLabel"
                               Grid.Column="2"
                               Text="0"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#2F2F2F"
                               VerticalOptions="Center" />
                    </Grid>
                </Frame>

                <Button Text="HOW TO PLAY"
                        HeightRequest="56"
                        CornerRadius="14"
                        BackgroundColor="#DF7B35"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        Clicked="OnHowToPlayClicked" />

                <Frame CornerRadius="20"
                       BackgroundColor="White"
                       HasShadow="False"
                       Padding="18,18,18,20"
                       Margin="0,10,0,0">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Challenge"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#E8A215" />

                        <BoxView HeightRequest="1"
                                 Color="#DBDBDB" />

                        <Label Text="Score above 3570 to rank up to Novice"
                               FontSize="16"
                               TextColor="#444444" />
                    </VerticalStackLayout>
                </Frame>

                <Frame CornerRadius="20"
                       BackgroundColor="White"
                       HasShadow="False"
                       Padding="18,18,18,20"
                       Margin="0,8,0,0">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Skills"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#E8A215" />

                        <BoxView HeightRequest="1"
                                 Color="#DBDBDB" />

                        <Frame CornerRadius="12"
                               BackgroundColor="#F8F8F8"
                               HasShadow="False"
                               Padding="14,10">
                            <Label Text="Working Memory"
                                   FontSize="16"
                                   TextColor="#333333" />
                        </Frame>

                        <Frame CornerRadius="12"
                               BackgroundColor="#F8F8F8"
                               HasShadow="False"
                               Padding="14,10">
                            <Label Text="Planning"
                                   FontSize="16"
                                   TextColor="#333333" />
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <BoxView HeightRequest="36" Opacity="0" />
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1"
              Padding="20,10,20,24"
              BackgroundColor="#DE7D2E">

            <Button Text="PLAY"
                    HeightRequest="64"
                    CornerRadius="32"
                    BackgroundColor="White"
                    TextColor="#E8A215"
                    FontAttributes="Bold"
                    FontSize="22"
                    Clicked="OnPlayClicked" />
        </Grid>

        <Grid x:Name="HowToPlayOverlay"
              IsVisible="False"
              Opacity="0"
              ZIndex="10">

            <BoxView BackgroundColor="#80000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnOverlayTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Grid VerticalOptions="End"
                  Padding="12,0,12,20">
                <Frame x:Name="HowToPlayPanel"
                       CornerRadius="28"
                       BackgroundColor="White"
                       HasShadow="False"
                       Padding="20"
                       TranslationY="500">

                    <VerticalStackLayout Spacing="16">
                        <BoxView HeightRequest="5"
                                 WidthRequest="46"
                                 Color="#D0D0D0"
                                 HorizontalOptions="Center" />

                        <Label Text="How to Play"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#222"
                               HorizontalOptions="Center" />

                        <Label Text="Memorize the safe route and avoid dangerous tiles while the grid shifts."
                               FontSize="16"
                               TextColor="#555" />

                        <Label Text="&#x2022; Watch the route before it disappears&#x0A;&#x2022; Tap the safe tiles in order&#x0A;&#x2022; Keep accuracy high to increase score"
                               FontSize="16"
                               TextColor="#444" />

                        <Button Text="Got it"
                                HeightRequest="54"
                                CornerRadius="27"
                                BackgroundColor="#E8A215"
                                TextColor="White"
                                Clicked="OnCloseHowToPlayClicked" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
