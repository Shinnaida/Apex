<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Peak.MovingMathInsightsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#47D85B"
    Padding="{OnPlatform Android='0,24,0,0', iOS='0,44,0,0'}"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*"
              BackgroundColor="#4CD35E"
              Padding="14,8,14,12">
            <Label Text="&#x2190;"
                   FontSize="28"
                   TextColor="White">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Label.GestureRecognizers>
            </Label>

            <Label Grid.Column="1"
                   FontAttributes="Bold"
                   FontSize="22"
                   HorizontalTextAlignment="Center"
                   Text="PERFORMANCE INSIGHTS"
                   TextColor="White"
                   VerticalTextAlignment="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="14,12,14,18"
                                 Spacing="12">
                <HorizontalStackLayout Spacing="8">
                    <Label FontAttributes="Bold"
                           FontSize="18"
                           Text="Score evolution"
                           TextColor="#EFFFF1" />
                    <Label FontSize="18"
                           Text="&#x21E7;"
                           TextColor="#EFFFF1"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <Grid HeightRequest="170"
                      IsClippedToBounds="True">
                    <BoxView CornerRadius="16"
                             Color="#5DE16F"
                             Opacity="0.15" />

                    <Grid x:Name="ChartPlot"
                          Margin="12,12,12,24"
                          IsClippedToBounds="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <BoxView Grid.Row="1"
                                 HeightRequest="1"
                                 Color="#ACF1B3"
                                 VerticalOptions="Center" />
                        <BoxView Grid.Row="2"
                                 HeightRequest="1"
                                 Color="#ACF1B3"
                                 VerticalOptions="Center" />
                        <BoxView Grid.Row="3"
                                 HeightRequest="1"
                                 Color="#ACF1B3"
                                 VerticalOptions="Center" />

                        <BoxView x:Name="RankUpGuide"
                                 Grid.Row="1"
                                 HeightRequest="1"
                                 Color="#E5FFE8"
                                 Opacity="0.8"
                                 VerticalOptions="Center" />

                        <BoxView x:Name="TrendLine"
                                 AnchorX="0"
                                 AnchorY="0.5"
                                 Color="White"
                                 HeightRequest="3"
                                 HorizontalOptions="Start"
                                 Rotation="-18"
                                 VerticalOptions="End"
                                 WidthRequest="260" />

                        <Border x:Name="EndPoint"
                                BackgroundColor="White"
                                HeightRequest="12"
                                HorizontalOptions="End"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 6"
                                VerticalOptions="Start"
                                WidthRequest="12" />

                        <Border x:Name="ScorePill"
                                BackgroundColor="White"
                                HorizontalOptions="End"
                                Padding="8,4"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 6"
                                VerticalOptions="Center">
                            <Label x:Name="ScorePillLabel"
                                   FontAttributes="Bold"
                                   FontSize="18"
                                   Text="0"
                                   TextColor="#48B856" />
                        </Border>
                    </Grid>

                    <Label x:Name="RankUpLabel"
                           FontSize="13"
                           HorizontalOptions="Center"
                           Margin="0,0,0,32"
                           Text="Rank up: 1390"
                           TextColor="#D7FFD9"
                           VerticalOptions="Center" />
                </Grid>

                <Border BackgroundColor="#4FD963"
                        Padding="16,14"
                        Stroke="#C8F9CF"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="1">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <Label FontAttributes="Bold"
                               FontSize="18"
                               Text="Rate this game!"
                               TextColor="White" />
                        <Label Grid.Column="1"
                               FontSize="24"
                               Margin="0,0,12,0"
                               Text="&#x1F44D;"
                               TextColor="White" />
                        <Label Grid.Column="2"
                               FontSize="24"
                               Text="&#x1F44E;"
                               TextColor="White" />
                    </Grid>
                </Border>

                <Border BackgroundColor="White"
                        Padding="14,10"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 18">
                    <Label x:Name="InsightBubbleLabel"
                           FontSize="16"
                           Text="That's a great debut!"
                           TextColor="#5D5D5D" />
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="2"
              Padding="14,8,14,12">
            <Grid>
                <Button BackgroundColor="White"
                        Clicked="OnReplayClicked"
                        CornerRadius="28"
                        FontAttributes="Bold"
                        FontSize="22"
                        HeightRequest="56"
                        Text="REPLAY"
                        TextColor="#48B856" />
                <Border BackgroundColor="#60DD70"
                        HorizontalOptions="End"
                        Margin="0,0,8,0"
                        Padding="0"
                        Stroke="#A4F0AF"
                        StrokeShape="RoundRectangle 18"
                        StrokeThickness="1"
                        VerticalOptions="Center"
                        WidthRequest="36"
                        HeightRequest="36">
                    <Label FontSize="18"
                           HorizontalTextAlignment="Center"
                           Text="&#x21BB;"
                           TextColor="White"
                           VerticalTextAlignment="Center" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
