<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Peak.WordALikeResultPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F3F3F3"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto" Padding="24,40,24,24">

        <VerticalStackLayout VerticalOptions="Center" Spacing="24">

            <Label Text="🏆"
                   FontSize="90"
                   HorizontalOptions="Center"/>

            <Border Stroke="#D9D9D9"
                    StrokeThickness="1"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 18"
                    Padding="0"
                    Margin="0,10,0,0">

                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                      Padding="24,34,24,28"
                      RowSpacing="10">

                    <Border x:Name="BestBanner"
                            BackgroundColor="#F7B500"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8"
                            HorizontalOptions="Center"
                            TranslationY="-26"
                            Padding="18,8">
                        <Label x:Name="BestBannerLabel"
                               Text="NEW BEST SCORE"
                               TextColor="White"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                    </Border>

                    <Label x:Name="FinalScoreLabel"
                           Grid.Row="1"
                           Text="11600"
                           FontSize="42"
                           FontAttributes="Bold"
                           TextColor="#5A57E3"
                           HorizontalOptions="Center"/>

                    <Label Grid.Row="2"
                           Text="Your score"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#333333"
                           HorizontalOptions="Center"/>

                    <Label x:Name="BestScoreLabel"
                           Grid.Row="3"
                           Text="Best score: 11600"
                           FontSize="16"
                           TextColor="#777777"
                           HorizontalOptions="Center"
                           Margin="0,8,0,0"/>
                </Grid>
            </Border>
        </VerticalStackLayout>

        <Button Grid.Row="1"
                Text="CONTINUE"
                HeightRequest="62"
                CornerRadius="31"
                BackgroundColor="#5A57E3"
                TextColor="White"
                FontSize="20"
                Clicked="OnContinueClicked"/>
    </Grid>
</ContentPage>