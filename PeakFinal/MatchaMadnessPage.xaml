<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Peak.MatchaMadnessPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#44E85E"
    Padding="{OnPlatform Android='0,26,0,0', iOS='0,44,0,0'}"
    Shell.NavBarIsVisible="False">

    <Grid>
        <Grid RowDefinitions="*,Auto">
            <ScrollView Grid.Row="0">
                <VerticalStackLayout Padding="20,18,20,24" Spacing="16">
                    <Label Text="&#x2190;"
                           FontSize="28"
                           TextColor="White">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped" />
                        </Label.GestureRecognizers>
                    </Label>

                    <Grid ColumnDefinitions="*,170"
                          Margin="0,8,0,0">
                        <VerticalStackLayout Spacing="8">
                            <Frame Padding="14,8"
                                   BackgroundColor="#82F196"
                                   CornerRadius="18"
                                   HasShadow="False"
                                   HorizontalOptions="Start">
                                <Label Text="New Game"
                                       FontAttributes="Bold"
                                       FontSize="16"
                                       TextColor="White" />
                            </Frame>

                            <Grid ColumnDefinitions="Auto,Auto,*">
                                <Label Text="Matcha Madness"
                                       FontAttributes="Bold"
                                       FontSize="28"
                                       TextColor="White"
                                       VerticalOptions="Center" />

                                <Label Grid.Column="1"
                                       Margin="12,4,0,0"
                                       FontSize="24"
                                       Text="&#x2606;"
                                       TextColor="White"
                                       VerticalOptions="Center" />
                            </Grid>

                            <Label Text="Problem Solving"
                                   FontAttributes="Bold"
                                   FontSize="16"
                                   TextColor="White" />

                            <BoxView HeightRequest="2"
                                     WidthRequest="180"
                                     HorizontalOptions="Start"
                                     Color="#D8FFD8" />

                            <Grid ColumnDefinitions="42,*"
                                  Margin="0,8,0,0">
                                <Frame WidthRequest="32"
                                       HeightRequest="32"
                                       Padding="0"
                                       BackgroundColor="Transparent"
                                       BorderColor="#D8FFD8"
                                       CornerRadius="16"
                                       HasShadow="False"
                                       VerticalOptions="Start">
                                    <Label Text="&#x21E7;"
                                           FontSize="15"
                                           HorizontalOptions="Center"
                                           TextColor="White"
                                           VerticalOptions="Center" />
                                </Frame>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="0">
                                    <Label Text="Best Rank"
                                           FontSize="14"
                                           TextColor="#E9FFEA" />
                                    <HorizontalStackLayout Spacing="8">
                                        <Label x:Name="BestRankLabel"
                                               Text="Beginner"
                                               FontAttributes="Bold"
                                               FontSize="20"
                                               TextColor="White" />
                                        <Label Text="i"
                                               FontSize="16"
                                               TextColor="White" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>

                        <Grid Grid.Column="1"
                              WidthRequest="170"
                              HeightRequest="170"
                              HorizontalOptions="End"
                              VerticalOptions="Start">
                            <Frame Padding="0"
                                   BackgroundColor="#62E975"
                                   CornerRadius="85"
                                   HasShadow="False" />

                            <Border WidthRequest="132"
                                    HeightRequest="132"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    BackgroundColor="#4DDC60"
                                    Padding="5"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8">
                                <Grid x:Name="PreviewBoard"
                                      RowDefinitions="*,*,*,*"
                                      ColumnDefinitions="*,*,*"
                                      ColumnSpacing="4"
                                      RowSpacing="4" />
                            </Border>
                        </Grid>
                    </Grid>

                    <Frame Padding="20,16"
                           BackgroundColor="White"
                           CornerRadius="18"
                           HasShadow="False">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Text="i"
                                   FontAttributes="Bold"
                                   FontSize="22"
                                   TextColor="#56E669"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Margin="12,0,0,0"
                                   FontAttributes="Bold"
                                   FontSize="18"
                                   Text="BEST SCORE"
                                   TextColor="#56E669"
                                   VerticalOptions="Center" />
                            <Label x:Name="BestScoreLabel"
                                   Grid.Column="2"
                                   FontAttributes="Bold"
                                   FontSize="24"
                                   Text="0"
                                   TextColor="#333333"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Frame>

                    <Grid HeightRequest="56">
                        <Button BackgroundColor="#07941E"
                                Clicked="OnHowToPlayClicked"
                                CornerRadius="14"
                                FontAttributes="Bold"
                                FontSize="16"
                                HeightRequest="56"
                                Padding="54,0,0,0"
                                Text="HOW TO PLAY"
                                TextColor="White" />
                        <Frame WidthRequest="34"
                               HeightRequest="34"
                               Margin="10,0,0,0"
                               Padding="0"
                               BackgroundColor="White"
                               CornerRadius="17"
                               HasShadow="False"
                               HorizontalOptions="Start"
                               VerticalOptions="Center">
                            <Label FontSize="16"
                                   HorizontalOptions="Center"
                                   Text="&#x1F393;"
                                   TextColor="#07941E"
                                   VerticalOptions="Center" />
                        </Frame>
                    </Grid>

                    <Frame Margin="0,8,0,0"
                           Padding="18,18,18,20"
                           BackgroundColor="White"
                           CornerRadius="20"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="16">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Text="&#x21E7;"
                                       FontSize="24"
                                       TextColor="#67E77B"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Margin="10,0,0,0"
                                       FontAttributes="Bold"
                                       FontSize="18"
                                       Text="Challenge"
                                       TextColor="#67E77B"
                                       VerticalOptions="Center" />
                            </Grid>

                            <Border Stroke="#CFCFCF"
                                    StrokeDashArray="4,4"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 1" />

                            <Label x:Name="ChallengeLabel"
                                   FontSize="16"
                                   Text="Score above 1300 to rank up to Novice"
                                   TextColor="#444444" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Margin="0,8,0,0"
                           Padding="18,18,18,20"
                           BackgroundColor="White"
                           CornerRadius="20"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="16">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Text="&#x1F3C6;"
                                       FontSize="24"
                                       TextColor="#67E77B"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Margin="10,0,0,0"
                                       FontAttributes="Bold"
                                       FontSize="18"
                                       Text="Scores"
                                       TextColor="#67E77B"
                                       VerticalOptions="Center" />
                            </Grid>

                            <Border Stroke="#CFCFCF"
                                    StrokeDashArray="4,4"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 1" />

                            <VerticalStackLayout Spacing="14">
                                <Label FontSize="16"
                                       Text="Recent Scores"
                                       TextColor="#444444" />

                                <Border BackgroundColor="#F7F7F7"
                                        Padding="16,10"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Label x:Name="RecentScoreLabel"
                                               FontAttributes="Bold"
                                               FontSize="16"
                                               Text="0"
                                               TextColor="#333333" />
                                        <Label x:Name="RecentTimeLabel"
                                               Grid.Column="1"
                                               FontSize="16"
                                               HorizontalTextAlignment="End"
                                               Text="No plays yet"
                                               TextColor="#9B9B9B" />
                                    </Grid>
                                </Border>

                                <Label FontSize="16"
                                       Text="Top Scores"
                                       TextColor="#444444" />

                                <Border BackgroundColor="#F7F7F7"
                                        Padding="16,10"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14">
                                    <Grid ColumnDefinitions="Auto,Auto,*">
                                        <Label Text="1"
                                               FontAttributes="Bold"
                                               FontSize="16"
                                               TextColor="#888888" />
                                        <Label x:Name="TopScoreLabel"
                                               Grid.Column="1"
                                               Margin="12,0,0,0"
                                               FontAttributes="Bold"
                                               FontSize="16"
                                               Text="0"
                                               TextColor="#333333" />
                                        <Label x:Name="TopTimeLabel"
                                               Grid.Column="2"
                                               FontSize="16"
                                               HorizontalTextAlignment="End"
                                               Text="No plays yet"
                                               TextColor="#9B9B9B" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Margin="0,8,0,0"
                           Padding="18,18,18,20"
                           BackgroundColor="White"
                           CornerRadius="20"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="16">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Text="&#x1F3A8;"
                                       FontSize="24"
                                       TextColor="#67E77B"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Margin="10,0,0,0"
                                       FontAttributes="Bold"
                                       FontSize="18"
                                       Text="Skills"
                                       TextColor="#67E77B"
                                       VerticalOptions="Center" />
                            </Grid>

                            <Border Stroke="#CFCFCF"
                                    StrokeDashArray="4,4"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 1" />

                            <Frame Padding="14,10"
                                   BackgroundColor="#F8F8F8"
                                   CornerRadius="12"
                                   HasShadow="False">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Text="&#x1F9E9;"
                                           FontSize="18"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1"
                                           Margin="12,0,0,0"
                                           FontSize="16"
                                           Text="Logic"
                                           TextColor="#333333"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Frame>

                            <Frame Padding="14,10"
                                   BackgroundColor="#F8F8F8"
                                   CornerRadius="12"
                                   HasShadow="False">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Text="&#x1F5D3;"
                                           FontSize="18"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1"
                                           Margin="12,0,0,0"
                                           FontSize="16"
                                           Text="Planning"
                                           TextColor="#333333"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Frame>

                            <Frame Padding="14,10"
                                   BackgroundColor="#F8F8F8"
                                   CornerRadius="12"
                                   HasShadow="False">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Text="&#x1F550;"
                                           FontSize="18"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1"
                                           Margin="12,0,0,0"
                                           FontSize="16"
                                           Text="Working Memory"
                                           TextColor="#333333"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Frame>
                        </VerticalStackLayout>
                    </Frame>

                    <BoxView HeightRequest="24"
                             Opacity="0" />
                </VerticalStackLayout>
            </ScrollView>

            <Grid Grid.Row="1"
                  RowDefinitions="Auto"
                  Padding="20,10,20,12"
                  BackgroundColor="#11B32B">
                <Button BackgroundColor="White"
                        Clicked="OnPlayClicked"
                        CornerRadius="32"
                        FontAttributes="Bold"
                        FontSize="22"
                        HeightRequest="64"
                        Text="PLAY"
                        TextColor="#67E77B" />
            </Grid>
        </Grid>

        <Grid x:Name="HowToPlayOverlay"
              IsVisible="False"
              Opacity="0"
              ZIndex="10">
            <BoxView BackgroundColor="#80000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnOverlayTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Grid Padding="12,0,12,20"
                  VerticalOptions="End">
                <Frame x:Name="HowToPlayPanel"
                       Padding="20"
                       BackgroundColor="White"
                       CornerRadius="28"
                       HasShadow="False"
                       TranslationY="500">
                    <VerticalStackLayout Spacing="16">
                        <BoxView WidthRequest="46"
                                 HeightRequest="5"
                                 Color="#D0D0D0"
                                 HorizontalOptions="Center" />

                        <Label FontAttributes="Bold"
                               FontSize="24"
                               HorizontalOptions="Center"
                               Text="How to Play"
                               TextColor="#222" />

                        <Label FontSize="16"
                               Text="Find and tap pairs that have the same visible top layer. When you make a correct match, that top layer disappears and reveals the next one underneath."
                               TextColor="#555" />

                        <Label FontSize="16"
                               Text="&#x2022; Match identical top layers&#x0A;&#x2022; Build combos to increase your multiplier&#x0A;&#x2022; Clear the whole board before the bonus drains"
                               TextColor="#444" />

                        <Button BackgroundColor="#11B32B"
                                Clicked="OnCloseHowToPlayClicked"
                                CornerRadius="27"
                                HeightRequest="54"
                                Text="Got it"
                                TextColor="White" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
