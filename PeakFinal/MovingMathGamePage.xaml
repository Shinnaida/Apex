<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Peak.MovingMathGamePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#2C5A48"
    Padding="{OnPlatform Android='0,18,0,0', iOS='0,42,0,0'}"
    Shell.NavBarIsVisible="False">

    <Grid>
        <Grid RowDefinitions="Auto,*,Auto">
            <Grid Grid.Row="0"
                  HeightRequest="52"
                  BackgroundColor="#162E29"
                  ColumnDefinitions="Auto,*,Auto,Auto"
                  ColumnSpacing="12"
                  Padding="14,0">
                <Border WidthRequest="28"
                        HeightRequest="28"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 2"
                        VerticalOptions="Center">
                    <Label Text="&#x23F8;"
                           FontSize="17"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="#202020"
                           VerticalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPauseTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </Border>

                <Label x:Name="TimerLabel"
                       Grid.Column="1"
                       FontSize="16"
                       HorizontalTextAlignment="Center"
                       Text="01:30"
                       TextColor="#D9BA59"
                       VerticalTextAlignment="Center" />

                <Label Grid.Column="2"
                       FontSize="13"
                       Margin="0,0,2,0"
                       Text="Score"
                       TextColor="#DCDCDC"
                       VerticalTextAlignment="Center" />

                <Label x:Name="ScoreLabel"
                       Grid.Column="3"
                       FontSize="16"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="End"
                       Text="0"
                       TextColor="#D9BA59"
                       VerticalTextAlignment="Center" />
            </Grid>

            <Grid Grid.Row="1"
                  Padding="14,14,14,12"
                  RowDefinitions="*,Auto"
                  RowSpacing="10">
                <Grid Grid.Row="0"
                      IsClippedToBounds="True">
                    <AbsoluteLayout x:Name="EquationArena" />
                </Grid>

                <Border Grid.Row="1"
                        BackgroundColor="#173B31"
                        Padding="14,10"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">
                    <Label x:Name="SelectionHintLabel"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"
                           MaxLines="2"
                           Text="Tap a blank slot or press a key to solve the lowest matching equation."
                           TextColor="#D5EBDD" />
                </Border>
            </Grid>

            <Grid Grid.Row="2"
                  BackgroundColor="#214438"
                  Padding="14,14,14,18">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="14">
                    <Grid RowDefinitions="Auto,Auto"
                          ColumnDefinitions="Auto,Auto,Auto,Auto"
                          ColumnSpacing="12"
                          RowSpacing="12">
                        <Button x:Name="Digit2Button"
                                Grid.Row="0"
                                Grid.Column="0"
                                BackgroundColor="#2DBEB2"
                                Clicked="OnNumberTapped"
                                CommandParameter="2"
                                CornerRadius="8"
                                FontAttributes="Bold"
                                FontSize="24"
                                HeightRequest="54"
                                Text="2"
                                TextColor="White"
                                WidthRequest="54" />
                        <Button x:Name="Digit3Button"
                                Grid.Row="0"
                                Grid.Column="1"
                                BackgroundColor="#2DBEB2"
                                Clicked="OnNumberTapped"
                                CommandParameter="3"
                                CornerRadius="8"
                                FontAttributes="Bold"
                                FontSize="24"
                                HeightRequest="54"
                                Text="3"
                                TextColor="White"
                                WidthRequest="54" />
                        <Button x:Name="Digit4Button"
                                Grid.Row="0"
                                Grid.Column="2"
                                BackgroundColor="#2DBEB2"
                                Clicked="OnNumberTapped"
                                CommandParameter="4"
                                CornerRadius="8"
                                FontAttributes="Bold"
                                FontSize="24"
                                HeightRequest="54"
                                Text="4"
                                TextColor="White"
                                WidthRequest="54" />
                        <Button x:Name="Digit5Button"
                                Grid.Row="0"
                                Grid.Column="3"
                                BackgroundColor="#2DBEB2"
                                Clicked="OnNumberTapped"
                                CommandParameter="5"
                                CornerRadius="8"
                                FontAttributes="Bold"
                                FontSize="24"
                                HeightRequest="54"
                                Text="5"
                                TextColor="White"
                                WidthRequest="54" />
                        <Button x:Name="Digit6Button"
                                Grid.Row="1"
                                Grid.Column="0"
                                BackgroundColor="#2DBEB2"
                                Clicked="OnNumberTapped"
                                CommandParameter="6"
                                CornerRadius="8"
                                FontAttributes="Bold"
                                FontSize="24"
                                HeightRequest="54"
                                Text="6"
                                TextColor="White"
                                WidthRequest="54" />
                        <Button x:Name="Digit7Button"
                                Grid.Row="1"
                                Grid.Column="1"
                                BackgroundColor="#2DBEB2"
                                Clicked="OnNumberTapped"
                                CommandParameter="7"
                                CornerRadius="8"
                                FontAttributes="Bold"
                                FontSize="24"
                                HeightRequest="54"
                                Text="7"
                                TextColor="White"
                                WidthRequest="54" />
                        <Button x:Name="Digit8Button"
                                Grid.Row="1"
                                Grid.Column="2"
                                BackgroundColor="#2DBEB2"
                                Clicked="OnNumberTapped"
                                CommandParameter="8"
                                CornerRadius="8"
                                FontAttributes="Bold"
                                FontSize="24"
                                HeightRequest="54"
                                Text="8"
                                TextColor="White"
                                WidthRequest="54" />
                        <Button x:Name="Digit9Button"
                                Grid.Row="1"
                                Grid.Column="3"
                                BackgroundColor="#2DBEB2"
                                Clicked="OnNumberTapped"
                                CommandParameter="9"
                                CornerRadius="8"
                                FontAttributes="Bold"
                                FontSize="24"
                                HeightRequest="54"
                                Text="9"
                                TextColor="White"
                                WidthRequest="54" />
                    </Grid>

                    <Grid Grid.Column="1"
                          RowDefinitions="Auto,Auto"
                          ColumnDefinitions="Auto,Auto"
                          ColumnSpacing="12"
                          RowSpacing="12">
                        <Button x:Name="AddButton"
                                Grid.Row="0"
                                Grid.Column="0"
                                BackgroundColor="#F5B11C"
                                Clicked="OnOperatorTapped"
                                CommandParameter="+"
                                CornerRadius="26"
                                FontAttributes="Bold"
                                FontSize="26"
                                HeightRequest="54"
                                Text="+"
                                TextColor="White"
                                WidthRequest="54" />
                        <Button x:Name="SubtractButton"
                                Grid.Row="0"
                                Grid.Column="1"
                                BackgroundColor="#F5B11C"
                                Clicked="OnOperatorTapped"
                                CommandParameter="-"
                                CornerRadius="26"
                                FontAttributes="Bold"
                                FontSize="28"
                                HeightRequest="54"
                                Text="−"
                                TextColor="White"
                                WidthRequest="54" />
                        <Button x:Name="MultiplyButton"
                                Grid.Row="1"
                                Grid.Column="0"
                                BackgroundColor="#F5B11C"
                                Clicked="OnOperatorTapped"
                                CommandParameter="*"
                                CornerRadius="26"
                                FontAttributes="Bold"
                                FontSize="24"
                                HeightRequest="54"
                                Text="×"
                                TextColor="White"
                                WidthRequest="54" />
                        <Button x:Name="DivideButton"
                                Grid.Row="1"
                                Grid.Column="1"
                                BackgroundColor="#F5B11C"
                                Clicked="OnOperatorTapped"
                                CommandParameter="/"
                                CornerRadius="26"
                                FontAttributes="Bold"
                                FontSize="24"
                                HeightRequest="54"
                                Text="÷"
                                TextColor="White"
                                WidthRequest="54" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <Label x:Name="ScoreDeltaLabel"
               Margin="0,52,18,0"
               FontSize="18"
               FontAttributes="Bold"
               HorizontalOptions="End"
               Opacity="0"
               Text="+125"
               TextColor="White"
               VerticalOptions="Start" />

        <Grid x:Name="CountdownOverlay"
              Grid.RowSpan="10"
              BackgroundColor="#FAF9FF"
              IsVisible="False"
              ZIndex="9">
            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="8"
                                 VerticalOptions="Center">
                <ActivityIndicator x:Name="LoadingSpinner"
                                   Color="#6AE084"
                                   HeightRequest="36"
                                   IsRunning="False"
                                   WidthRequest="36" />
                <Label x:Name="CountdownValueLabel"
                       FontSize="54"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       Text=""
                       TextColor="#6AE084" />
                <Label x:Name="CountdownCaptionLabel"
                       FontSize="20"
                       HorizontalTextAlignment="Center"
                       Text=""
                       TextColor="#6A6A6A" />
            </VerticalStackLayout>
        </Grid>

        <Grid x:Name="PauseOverlay"
              Grid.RowSpan="10"
              BackgroundColor="#88000000"
              IsVisible="False"
              ZIndex="10">
            <Border BackgroundColor="White"
                    HorizontalOptions="Center"
                    Padding="22,20"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 22"
                    VerticalOptions="Center"
                    WidthRequest="282">
                <VerticalStackLayout Spacing="14">
                    <Label FontAttributes="Bold"
                           FontSize="26"
                           HorizontalTextAlignment="Center"
                           Text="Paused"
                           TextColor="#203622" />
                    <Button BackgroundColor="#35C857"
                            Clicked="OnResumeClicked"
                            CornerRadius="24"
                            HeightRequest="50"
                            Text="Resume"
                            TextColor="White" />
                    <Button BackgroundColor="#EEF1F2"
                            Clicked="OnQuitClicked"
                            CornerRadius="24"
                            HeightRequest="50"
                            Text="Quit"
                            TextColor="#31433F" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid x:Name="ResultOverlay"
              Grid.RowSpan="10"
              BackgroundColor="#FBFBFF"
              IsVisible="False"
              ZIndex="11">
            <AbsoluteLayout x:Name="ConfettiLayer"
                            InputTransparent="True" />

            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="18"
                                 VerticalOptions="Center">
                <Label Text="Your score"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="#72DA84" />

                <Border BackgroundColor="White"
                        Padding="0"
                        Stroke="#D8D8E3"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="1"
                        WidthRequest="334">
                    <VerticalStackLayout Spacing="0">
                        <VerticalStackLayout Padding="18,18,18,16"
                                             Spacing="4">
                            <Label x:Name="ResultScoreLabel"
                                   FontSize="54"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   Text="0"
                                   TextColor="#303030" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1"
                                 Color="#E6E6EE" />

                        <Grid Padding="18,16,18,18"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="16">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Text="&#x1F3C6;"
                                       FontSize="28"
                                       VerticalTextAlignment="Center" />
                                <VerticalStackLayout Grid.Column="1"
                                                     Margin="12,0,0,0"
                                                     Spacing="0">
                                    <Label x:Name="BestBadgeTextLabel"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           Text="New best score"
                                           TextColor="#72DA84" />
                                    <Label x:Name="BestScoreValueLabel"
                                           FontSize="18"
                                           Text="0"
                                           TextColor="#333333" />
                                </VerticalStackLayout>
                            </Grid>

                            <Grid Grid.Row="1"
                                  ColumnDefinitions="Auto,*">
                                <Label Text="&#x1F6E1;"
                                       FontSize="28"
                                       VerticalTextAlignment="Center" />
                                <VerticalStackLayout Grid.Column="1"
                                                     Margin="12,0,0,0"
                                                     Spacing="0">
                                    <Label x:Name="RankUpLabel"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           Text="Rank"
                                           TextColor="#72DA84" />
                                    <Label x:Name="RankValueLabel"
                                           FontSize="18"
                                           Text="Novice"
                                           TextColor="#333333" />
                                </VerticalStackLayout>
                            </Grid>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Button BackgroundColor="#3FD055"
                        Clicked="OnContinueClicked"
                        CornerRadius="24"
                        HeightRequest="56"
                        Text="CONTINUE"
                        TextColor="White"
                        WidthRequest="332" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
