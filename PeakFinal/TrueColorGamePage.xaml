<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Peak.TrueColorGamePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#0A56D3"
    Padding="{OnPlatform Android='0,20,0,0', iOS='0,42,0,0'}"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <Grid Grid.Row="0"
              BackgroundColor="#0949B7"
              ColumnDefinitions="Auto,*,Auto,Auto"
              ColumnSpacing="10"
              HeightRequest="52"
              Padding="14,0">
            <Border WidthRequest="30"
                    HeightRequest="30"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 4"
                    VerticalOptions="Center">
                <Label FontAttributes="Bold"
                       FontSize="18"
                       HorizontalTextAlignment="Center"
                       Text="&#x23F8;"
                       TextColor="#2B2B2B"
                       VerticalTextAlignment="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPauseTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>

            <Label x:Name="TimerLabel"
                   Grid.Column="1"
                   FontAttributes="Bold"
                   FontSize="20"
                   HorizontalTextAlignment="Center"
                   Text="00:45"
                   TextColor="#FDE37A"
                   VerticalTextAlignment="Center" />

            <Border x:Name="StreakBadge"
                    Grid.Column="2"
                    BackgroundColor="#2B84F2"
                    Padding="10,4"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    VerticalOptions="Center">
                <Label x:Name="StreakLabel"
                       FontAttributes="Bold"
                       FontSize="13"
                       Text="Streak 0"
                       TextColor="White" />
            </Border>

            <VerticalStackLayout Grid.Column="3"
                                 HorizontalOptions="End"
                                 Spacing="0"
                                 VerticalOptions="Center">
                <Label FontSize="12"
                       HorizontalTextAlignment="End"
                       Text="Score"
                       TextColor="#D5EBFF" />
                <Label x:Name="ScoreLabel"
                       FontAttributes="Bold"
                       FontSize="20"
                       HorizontalTextAlignment="End"
                       Text="0"
                       TextColor="#FDE37A" />
            </VerticalStackLayout>
        </Grid>

        <Border Grid.Row="1"
                BackgroundColor="#1063DD"
                Margin="14,12,14,0"
                Padding="14,12"
                Stroke="#71B7FF"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="1.5">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="12">
                <Border BackgroundColor="#68AAFF"
                        HeightRequest="48"
                        Padding="0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14"
                        WidthRequest="48"
                        VerticalOptions="Center">
                    <Label FontAttributes="Bold"
                           FontSize="23"
                           HorizontalTextAlignment="Center"
                           Text="&#x25C9;"
                           TextColor="White"
                           VerticalTextAlignment="Center" />
                </Border>

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="2"
                                     VerticalOptions="Center">
                    <Label x:Name="ObjectiveCaptionLabel"
                           FontAttributes="Bold"
                           FontSize="12"
                           Text="MATCH THE WORD TO THE INK COLOR"
                           TextColor="#DBEEFF" />
                    <Label x:Name="TargetPromptLabel"
                           FontAttributes="Bold"
                           FontSize="20"
                           LineBreakMode="WordWrap"
                           MaxLines="2"
                           Text="Is the top word the true color?"
                           TextColor="White" />
                </VerticalStackLayout>

                <Border Grid.Column="2"
                        BackgroundColor="#2A82F0"
                        Padding="10,6"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14"
                        VerticalOptions="Start">
                    <Label x:Name="StageLabel"
                           FontAttributes="Bold"
                           FontSize="12"
                           Text="LEVEL 1"
                           TextColor="#F2F8FF" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              Margin="14,12,14,0">
            <Border x:Name="BoardShell"
                    BackgroundColor="#0E61DB"
                    Padding="18"
                    Stroke="#70B9FF"
                    StrokeShape="RoundRectangle 28"
                    StrokeThickness="1.5">
                <Grid RowDefinitions="Auto,Auto,*,Auto"
                      RowSpacing="14">
                    <HorizontalStackLayout Spacing="8">
                        <Label FontAttributes="Bold"
                               FontSize="14"
                               Text="Prompt"
                               TextColor="#E9F5FF" />
                        <Label x:Name="InstructionLabel"
                               FontSize="14"
                               Text="Ignore the bottom word meaning."
                               TextColor="#CDE7FF" />
                    </HorizontalStackLayout>

                    <VerticalStackLayout Grid.Row="1"
                                         Spacing="0">
                        <Border x:Name="TopCard"
                                BackgroundColor="#72B0FF"
                                Padding="0"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 26"
                                HeightRequest="122">
                            <Grid>
                                <HorizontalStackLayout HorizontalOptions="Center"
                                                       Spacing="10"
                                                       VerticalOptions="Start"
                                                       Margin="0,18,0,0">
                                    <BoxView WidthRequest="22"
                                             HeightRequest="6"
                                             Color="#E6F2FF"
                                             CornerRadius="2" />
                                    <BoxView WidthRequest="22"
                                             HeightRequest="6"
                                             Color="#E6F2FF"
                                             CornerRadius="2" />
                                    <BoxView WidthRequest="22"
                                             HeightRequest="6"
                                             Color="#E6F2FF"
                                             CornerRadius="2" />
                                    <BoxView WidthRequest="22"
                                             HeightRequest="6"
                                             Color="#E6F2FF"
                                             CornerRadius="2" />
                                </HorizontalStackLayout>

                                <Label x:Name="TopWordLabel"
                                       FontAttributes="Bold"
                                       FontSize="34"
                                       HorizontalTextAlignment="Center"
                                       Text="BLUE"
                                       TextColor="White"
                                       VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border x:Name="BottomCard"
                                BackgroundColor="White"
                                Padding="0"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                HeightRequest="170">
                            <Grid>
                                <HorizontalStackLayout HorizontalOptions="Center"
                                                       Spacing="12"
                                                       VerticalOptions="Start"
                                                       Margin="0,22,0,0">
                                    <BoxView WidthRequest="22"
                                             HeightRequest="6"
                                             Color="#3295FF"
                                             CornerRadius="2" />
                                    <BoxView WidthRequest="22"
                                             HeightRequest="6"
                                             Color="#3295FF"
                                             CornerRadius="2" />
                                    <BoxView WidthRequest="22"
                                             HeightRequest="6"
                                             Color="#3295FF"
                                             CornerRadius="2" />
                                </HorizontalStackLayout>

                                <Label x:Name="BottomWordLabel"
                                       FontAttributes="Bold"
                                       FontSize="42"
                                       HorizontalTextAlignment="Center"
                                       Text="GREEN"
                                       TextColor="#FF4A56"
                                       VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <Border Grid.Row="2"
                            BackgroundColor="#0A54C8"
                            Padding="14,10"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            VerticalOptions="End">
                        <Label x:Name="HintLabel"
                               FontSize="14"
                               HorizontalTextAlignment="Center"
                               Text="Tap TRUE when the top word matches the bottom ink color."
                               TextColor="#DCEEFF" />
                    </Border>

                    <Grid Grid.Row="3"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="14">
                        <Button x:Name="TrueButton"
                                BackgroundColor="White"
                                Clicked="OnTrueClicked"
                                CornerRadius="26"
                                FontAttributes="Bold"
                                FontSize="24"
                                HeightRequest="60"
                                Text="TRUE"
                                TextColor="#1A86FF" />

                        <Button x:Name="FalseButton"
                                Grid.Column="1"
                                BackgroundColor="#083A8A"
                                Clicked="OnFalseClicked"
                                CornerRadius="26"
                                FontAttributes="Bold"
                                FontSize="24"
                                HeightRequest="60"
                                Text="FALSE"
                                TextColor="White" />
                    </Grid>
                </Grid>
            </Border>

            <Label x:Name="ScoreDeltaLabel"
                   FontAttributes="Bold"
                   FontSize="22"
                   HorizontalOptions="Center"
                   Margin="0,18,0,0"
                   Opacity="0"
                   Text="+120"
                   TextColor="White"
                   VerticalOptions="Start" />
        </Grid>

        <Border Grid.Row="3"
                Margin="14,12,14,14"
                BackgroundColor="#0A4EBD"
                Padding="16,10"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 18">
            <Label x:Name="DifficultyHintLabel"
                   FontSize="14"
                   HorizontalTextAlignment="Center"
                   Text="More colors unlock as your score goes up."
                   TextColor="#D8ECFF" />
        </Border>

        <Grid x:Name="CountdownOverlay"
              Grid.RowSpan="10"
              BackgroundColor="#F4F9FF"
              IsVisible="False"
              ZIndex="20">
            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="10"
                                 VerticalOptions="Center">
                <ActivityIndicator x:Name="LoadingSpinner"
                                   Color="#2C91FF"
                                   HeightRequest="36"
                                   IsRunning="False"
                                   WidthRequest="36" />
                <Label x:Name="CountdownCaptionLabel"
                       FontAttributes="Bold"
                       FontSize="26"
                       HorizontalTextAlignment="Center"
                       Text="GET READY"
                       TextColor="#0F6AE8" />
                <Label x:Name="CountdownValueLabel"
                       FontAttributes="Bold"
                       FontSize="58"
                       HorizontalTextAlignment="Center"
                       Text="3"
                       TextColor="#2C91FF" />
            </VerticalStackLayout>
        </Grid>

        <Grid x:Name="PauseOverlay"
              Grid.RowSpan="10"
              BackgroundColor="#99000000"
              IsVisible="False"
              ZIndex="21">
            <Border BackgroundColor="White"
                    HorizontalOptions="Center"
                    Padding="22,20"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 22"
                    VerticalOptions="Center"
                    WidthRequest="286">
                <VerticalStackLayout Spacing="14">
                    <Label FontAttributes="Bold"
                           FontSize="26"
                           HorizontalTextAlignment="Center"
                           Text="Paused"
                           TextColor="#24457B" />
                    <Button BackgroundColor="#2890FF"
                            Clicked="OnResumeClicked"
                            CornerRadius="24"
                            HeightRequest="50"
                            Text="Resume"
                            TextColor="White" />
                    <Button BackgroundColor="#EEF4F9"
                            Clicked="OnQuitClicked"
                            CornerRadius="24"
                            HeightRequest="50"
                            Text="Quit"
                            TextColor="#31433F" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid x:Name="ResultOverlay"
              Grid.RowSpan="10"
              BackgroundColor="#F4F9FF"
              IsVisible="False"
              ZIndex="22">
            <VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="18"
                                 VerticalOptions="Center">
                <Label FontSize="68"
                       HorizontalTextAlignment="Center"
                       Text="&#x1F3C6;"
                       TextColor="#2D92FF" />

                <Border BackgroundColor="White"
                        Padding="20,18"
                        Stroke="#D7E8FA"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        WidthRequest="320">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="ResultBadgeLabel"
                               FontAttributes="Bold"
                               FontSize="15"
                               HorizontalTextAlignment="Center"
                               Text="NEW BEST SCORE"
                               TextColor="#2D92FF" />
                        <Label x:Name="ResultScoreLabel"
                               FontAttributes="Bold"
                               FontSize="52"
                               HorizontalTextAlignment="Center"
                               Text="0"
                               TextColor="#2E2E2E" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <Border BackgroundColor="#EEF6FF"
                                    Padding="12,10"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14">
                                <VerticalStackLayout Spacing="2">
                                    <Label FontSize="12"
                                           Text="Best"
                                           TextColor="#5D7AA2" />
                                    <Label x:Name="ResultBestLabel"
                                           FontAttributes="Bold"
                                           FontSize="20"
                                           Text="0"
                                           TextColor="#2D92FF" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1"
                                    BackgroundColor="#EEF6FF"
                                    Padding="12,10"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14">
                                <VerticalStackLayout Spacing="2">
                                    <Label FontSize="12"
                                           Text="Rank"
                                           TextColor="#5D7AA2" />
                                    <Label x:Name="ResultRankLabel"
                                           FontAttributes="Bold"
                                           FontSize="20"
                                           Text="Novice"
                                           TextColor="#2D92FF" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Button BackgroundColor="#2D92FF"
                        Clicked="OnContinueClicked"
                        CornerRadius="26"
                        HeightRequest="56"
                        Text="CONTINUE"
                        TextColor="White"
                        WidthRequest="320" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
